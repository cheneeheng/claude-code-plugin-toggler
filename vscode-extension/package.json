{
  "name": "claude-code-plugin-toggler",
  "displayName": "Claude Code Plugin Toggler",
  "version": "0.1.0",
  "description": "Manage Claude Code skill plugins across projects.",
  "engines": { "vscode": "^1.80.0" },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillsToggle",
          "title": "Skills Toggle",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "skillsToggle": [
        {
          "type": "webview",
          "id": "skillsToggle.pluginList",
          "name": "Plugins"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
