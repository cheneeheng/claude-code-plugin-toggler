{
  "env": {
    "node": true,
    "es2020": true
  },
  "plugins": ["n"],
  "extends": ["eslint:recommended", "plugin:n/recommended"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "n/no-missing-require": "error",
    "n/no-unpublished-require": "off"
  },
  "ignorePatterns": ["node_modules/", "dist/"]
}
